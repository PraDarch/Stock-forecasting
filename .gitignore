.installed.cfg
*.egg
MANIFEST

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

