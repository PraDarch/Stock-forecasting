node_modules/
dashboard/node_modules/
dashboard/dist/
.vite/

# Quantitative Data / Checkpoints (Keep structure, ignore raw bulk files)
data/raw/*.csv
data/processed/*.csv
results/models/*.pth
results/plots/*.png
results/metrics/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep
!results/models/.gitkeep
!results/plots/.gitkeep
!results/metrics/.gitkeep
